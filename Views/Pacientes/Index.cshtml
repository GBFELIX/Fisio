@model IEnumerable<PlanTributario.Models.Paciente>

@{
    ViewData["Title"] = "Gestão de Pacientes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 text-primary mb-0"><i class="fas fa-users"></i> Pacientes</h1>
            <p class="text-muted">Cadastro base para identificação nos prontuários</p>
        </div>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="fas fa-user-plus"></i> Novo Paciente
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Nome do Paciente</th>
                            <th>Contato</th>
                            <th>Cidade/Bairro</th>
                            <th>Profissão</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    Nenhum paciente cadastrado.
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.Nome</div>
                                    <small class="text-muted">ID: #@item.Id</small>
                                </td>
                                <td><i class="fab fa-whatsapp text-success me-1"></i> @item.Telefone</td>
                                <td>@item.Cidade / @item.Bairro</td>
                                <td>@item.Profissao</td>
                                <td class="text-center pe-4">
                                    <div class="btn-group">
                                        <a asp-controller="Prontuarios"
                                           asp-action="Criar"
                                           asp-route-lancamentoId="@item.Id"
                                           asp-route-pacienteId="@item.Id"
                                           class="btn btn-sm btn-outline-primary" title="Novo Prontuário">
                                            <i class="fas fa-notes-medical"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding-top: 15px;
        padding-bottom: 15px;
    }

    .card {
        border-radius: 12px;
        overflow: hidden;
    }

    .btn-group .btn {
        padding: 0.4rem 0.8rem;
    }
</style>