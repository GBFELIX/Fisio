@model PlanTributario.Models.Paciente

@{
    ViewData["Title"] = "Excluir Paciente";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-danger text-white p-3">
                    <h4 class="mb-0"><i class="fas fa-exclamation-triangle me-2"></i> Confirmar Exclusão</h4>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <i class="fas fa-user-times fa-4x text-danger opacity-25"></i>
                    </div>

                    <h3 class="text-dark mb-3">Tem certeza que deseja excluir este paciente?</h3>
                    <p class="text-muted mb-4">
                        Esta ação é <strong>permanente</strong>. Ao excluir o paciente, todos os
                        <span class="badge bg-danger">prontuários clínicos</span> e históricos vinculados a ele também serão apagados do banco de dados.
                    </p>

                    <div class="alert alert-light border text-start mb-4">
                        <div class="row">
                            <div class="col-sm-4 fw-bold text-uppercase small text-muted">Nome:</div>
                            <div class="col-sm-8 fw-bold">@Model.Nome</div>
                        </div>
                        <hr class="my-2">
                        <div class="row">
                            <div class="col-sm-4 fw-bold text-uppercase small text-muted">Telefone:</div>
                            <div class="col-sm-8">@Model.Telefone</div>
                        </div>
                        <hr class="my-2">
                        <div class="row">
                            <div class="col-sm-4 fw-bold text-uppercase small text-muted">ID do Cadastro:</div>
                            <div class="col-sm-8">#@Model.Id</div>
                        </div>
                    </div>

                    <form asp-action="DeleteConfirmed" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="fas fa-arrow-left me-1"></i> Cancelar e Voltar
                            </a>
                            <button type="submit" class="btn btn-danger btn-lg px-5 shadow">
                                <i class="fas fa-trash-alt me-1"></i> Confirmar Exclusão Permanente
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>