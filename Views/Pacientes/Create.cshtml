@model PlanTributario.Models.Paciente

@{
    ViewData["Title"] = "Cadastrar Novo Paciente";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white p-3">
                    <h4 class="mb-0"><i class="fas fa-user-plus me-2"></i> Cadastro de Identificação (Parte 1)</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-12">
                                <label asp-for="Nome" class="form-label fw-bold"></label>
                                <input asp-for="Nome" class="form-control" placeholder="Digite o nome completo do paciente" />
                                <span asp-validation-for="Nome" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="DataNascimento" class="form-label fw-bold"></label>
                                <input asp-for="DataNascimento" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Telefone" class="form-label fw-bold"></label>
                                <input asp-for="Telefone" class="form-control" placeholder="(00) 00000-0000" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Sexo" class="form-label fw-bold"></label>
                                <select asp-for="Sexo" class="form-select">
                                    <option value="">Selecione...</option>
                                    <option value="Feminino">Feminino</option>
                                    <option value="Masculino">Masculino</option>
                                    <option value="Outro">Outro</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Cidade" class="form-label fw-bold"></label>
                                <input asp-for="Cidade" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Bairro" class="form-label fw-bold"></label>
                                <input asp-for="Bairro" class="form-control" />
                            </div>

                            <div class="col-md-8">
                                <label asp-for="Profissao" class="form-label fw-bold"></label>
                                <input asp-for="Profissao" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="EstadoCivil" class="form-label fw-bold"></label>
                                <select asp-for="EstadoCivil" class="form-select">
                                    <option value="">Selecione...</option>
                                    <option value="Solteiro(a)">Solteiro(a)</option>
                                    <option value="Casado(a)">Casado(a)</option>
                                    <option value="Divorciado(a)">Divorciado(a)</option>
                                    <option value="Viúvo(a)">Viúvo(a)</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Naturalidade" class="form-label fw-bold"></label>
                                <input asp-for="Naturalidade" class="form-control" placeholder="Cidade onde nasceu" />
                            </div>
                            <div class="col-md-12">
                                <label asp-for="EnderecoResidencial" class="form-label fw-bold"></label>
                                <textarea asp-for="EnderecoResidencial" class="form-control" rows="2" placeholder="Rua, número, complemento..."></textarea>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
                            <button type="submit" class="btn btn-primary btn-lg px-5 shadow">
                                <i class="fas fa-save me-2"></i>Salvar Cadastro
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}