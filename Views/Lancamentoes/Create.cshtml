@model PlanTributario.Models.Lancamento

<form asp-action="Create" enctype="multipart/form-data" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Data" class="control-label font-weight-bold"></label>
        <input asp-for="Data" type="datetime-local" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" class="form-control" />
        <span asp-validation-for="Data" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Descricao" class="control-label font-weight-bold"></label>
        <input asp-for="Descricao" class="form-control" placeholder="Nome do Paciente / Clínica" />
        <span asp-validation-for="Descricao" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ValorBruto" class="control-label font-weight-bold"></label>
        <input asp-for="ValorBruto" id="inputValorBruto" type="number" step="0.01" inputmode="decimal" class="form-control" placeholder="0,00" />
        <span asp-validation-for="ValorBruto" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="TipoAtendimento" class="control-label font-weight-bold"></label>
        <select asp-for="TipoAtendimento" class="form-control">
            <option value="Particular">Particular</option>
            <option value="Clinica">Clínica</option>
        </select>
        <span asp-validation-for="TipoAtendimento" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label class="form-label fw-bold">Anexar Prontuário (PDF/Imagem)</label>
        <input type="file" name="arquivoProntuario" class="form-control" accept=".pdf,.jpg,.jpeg,.png" />
    </div>
    <div class="modal-footer px-0 pb-0">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-success">Salvar Lançamento</button>
    </div>
</form>