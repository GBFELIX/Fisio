@model PlanTributario.Models.Lancamento

@{
    ViewData["Title"] = "Excluir Lançamento";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white text-center">
                    <h4 class="mb-0"><i class="fas fa-exclamation-triangle"></i> Atenção!</h4>
                </div>
                <div class="card-body">
                    <h5 class="text-center mb-4">Tem certeza que deseja excluir este atendimento?</h5>
                    <p class="text-muted text-center">Essa ação não pode ser desfeita.</p>

                    <hr />

                    <dl class="row px-3">
                        <dt class="col-sm-5 text-muted">Data:</dt>
                        <dd class="col-sm-7 font-weight-bold">@Model.Data.ToString("dd/MM/yyyy")</dd>

                        <dt class="col-sm-5 text-muted">Descrição:</dt>
                        <dd class="col-sm-7">@Model.Descricao</dd>

                        <dt class="col-sm-5 text-muted">Tipo:</dt>
                        <dd class="col-sm-7">
                            <span class="badge @(Model.TipoAtendimento == "Particular" ? "bg-success" : "bg-info") text-white">
                                @Model.TipoAtendimento
                            </span>
                        </dd>

                        <dt class="col-sm-5 text-muted">Valor Bruto:</dt>
                        <dd class="col-sm-7 text-danger font-weight-bold">@Model.ValorBruto.ToString("C")</dd>
                    </dl>

                    <hr />

                    <form asp-action="Delete" class="d-flex justify-content-between mt-4">
                        <input type="hidden" asp-for="Id" />
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-danger btn-lg px-4 shadow-sm">
                            <i class="fas fa-trash-alt"></i> Confirmar Exclusão
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>